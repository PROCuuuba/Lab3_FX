<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.lab3_fx.MainController">

    <center>
        <ImageView fx:id="imageView"
                   fitWidth="600"
                   fitHeight="400"
                   preserveRatio="true"/>
    </center>

    <bottom>

        <VBox spacing="10" alignment="CENTER">

            <Label fx:id="positionLabel"/>

            <HBox spacing="10" alignment="CENTER">

                <Button text="&lt;" onAction="#prevImage"/>
                <Button text="&gt;" onAction="#nextImage"/>
                <Button text="&lt;&lt;" onAction="#firstImage"/>
                <Button text="&gt;&gt;" onAction="#lastImage"/>

            </HBox>

            <HBox spacing="10" alignment="CENTER">

                <Button text="Загрузить папку" onAction="#loadFolder"/>
                <Button text="Автопросмотр" onAction="#autoPlay"/>

                <ChoiceBox fx:id="filterChoice"/>

            </HBox>

            <Label fx:id="fileInfo" wrapText="true"/>

        </VBox>

    </bottom>

</BorderPane>